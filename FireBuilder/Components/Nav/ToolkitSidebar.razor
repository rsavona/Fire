@using FireBuilder.Services
@inject DeviceDiscoveryService DiscoveryService

<div class="flex-grow-1 overflow-auto h-100" style="background-color: #CE2029; min-height: 100vh;">
    <div class="sidebar-section-header" style="background-color: rgba(0,0,0,0.2); color: white; padding: 10px 15px; font-size: 0.75rem; font-weight: bold; text-transform: uppercase;">Devices</div>
    <div class="nav flex-column nav-pills gap-1 p-2">
        @foreach (var deviceType in DiscoveryService.GetDiscoveredDevices())
        {
            <div class="nav-link text-white toolbox-item d-flex align-items-center gap-2 rounded p-2 mb-1" 
                 style="cursor: grab; background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1);"
                 draggable="true" 
                 @ondragstart="@(() => HandleDragStart(deviceType.Name))">
                <i class="bi @GetIconForType(deviceType.Name) text-white"></i> <span class="small text-white">@FormatName(deviceType.Name)</span>
            </div>
        }
    </div>
    
    <div class="sidebar-section-header mt-2" style="background-color: rgba(0,0,0,0.2); color: white; padding: 10px 15px; font-size: 0.75rem; font-weight: bold; text-transform: uppercase;">Workflows</div>
    <div class="nav flex-column nav-pills gap-1 p-2">
        @foreach (var wfType in DiscoveryService.GetDiscoveredWorkflows())
        {
            <div class="nav-link text-white toolbox-item d-flex align-items-center gap-2 rounded p-2 mb-1" 
                 style="cursor: grab; background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1);"
                 draggable="true" 
                 @ondragstart="@(() => HandleDragStart("Workflow"))">
                <i class="bi bi-diagram-3 text-white"></i> <span class="small text-white">@wfType.Name</span>
            </div>
        }

        @if (!DiscoveryService.GetDiscoveredWorkflows().Any())
        {
            <div class="nav-link text-white toolbox-item d-flex align-items-center gap-2 rounded p-2" 
                 style="cursor: grab; background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1);"
                 draggable="true" 
                 @ondragstart="@(() => HandleDragStart("Workflow"))">
                <i class="bi bi-diagram-3 text-white"></i> <span class="small text-white">Workflow</span>
            </div>
        }
    </div>
</div>

@code {
    /// <summary>
    /// Event triggered when a user starts dragging a toolkit item.
    /// Passes the string identifier of the device type.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnItemDragStart { get; set; }

    private async Task HandleDragStart(string deviceType)
    {
        await OnItemDragStart.InvokeAsync(deviceType);
    }

    private string GetIconForType(string typeName) => typeName switch
    {
        string s when s.Contains("Plc") && s.Contains("Virtual") => "bi-cpu text-white-50",
        string s when s.Contains("Plc") => "bi-hdd-rack text-danger",
        string s when s.Contains("Printer") && s.Contains("Virtual") => "bi-file-earmark-code text-white-50",
        string s when s.Contains("Printer") => "bi-printer text-warning",
        string s when s.Contains("ActiveMq") => "bi-envelope-paper text-info",
        string s when s.Contains("Database") => "bi-database-fill text-primary",
        string s when s.Contains("Api") || s.Contains("Controller") => "bi-cloud-arrow-down text-success",
        _ => "bi-box text-muted"
    };

    private string FormatName(string name)
    {
        return name.Replace("Device", "").Replace("Server", "").Replace("Client", "");
    }
}