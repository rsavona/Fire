<div class="modal-backdrop-custom">
    <div class="modal-content-fire" style="width: 600px;">
        <div class="modal-header-fire">
            <h6>Field Mapper</h6>
            <button class="btn-close btn-close-white" @onclick="OnClose"></button>
        </div>
        <div class="modal-body p-3 bg-light">
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <select class="form-select" @bind="_builderInput">
                        @foreach(var m in MessageTypes){<option value="@m">@m</option>}
                    </select>
                </div>
                <div class="col-6">
                    <select class="form-select" @bind="_builderOutput">
                        @foreach(var m in MessageTypes){<option value="@m">@m</option>}
                    </select>
                </div>
            </div>
            <div class="row g-2 bg-white border p-2" style="max-height: 250px; overflow-y: auto;">
                <div class="col-5">
                    @foreach(var f in MessageSchemas[_builderInput]){
                        <div class="p-2 mb-1 mapper-field @(_activeSourceField == f ? "active" : "")" @onclick="() => _activeSourceField = f">@f</div>
                    }
                </div>
                <div class="col-2 text-center pt-4"><i class="bi bi-arrow-right fs-4"></i></div>
                <div class="col-5">
                    @foreach(var f in MessageSchemas[_builderOutput]){
                        var map = _currentMappings.FirstOrDefault(m => m.Target == f);
                        <div class="p-2 mb-1 mapper-field" @onclick="() => ConnectToTargetField(f)">
                            <strong>@f</strong> @if(map.Source != null){ <span class="text-primary d-block small">@map.Source</span> }
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="modal-footer p-2">
            <button class="btn btn-sm btn-warning w-100" @onclick="Apply">Apply</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Dictionary<string, List<string>> MessageSchemas { get; set; } = new();
    [Parameter] public EventCallback<string> OnApply { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<string> MessageTypes => MessageSchemas.Keys.ToList();
    private string _builderInput;
    private string _builderOutput;
    private string _activeSourceField;
    private List<(string Source, string Target)> _currentMappings = new();

    protected override void OnInitialized()
    {
        _builderInput = MessageTypes.FirstOrDefault();
        _builderOutput = MessageTypes.FirstOrDefault();
    }

    private void ConnectToTargetField(string target) 
    { 
        if (!string.IsNullOrEmpty(_activeSourceField)) 
        { 
            _currentMappings.RemoveAll(m => m.Target == target); 
            _currentMappings.Add((_activeSourceField, target)); 
            _activeSourceField = null; 
        } 
    }

    private async Task Apply()
    {
        var mapString = string.Join(",", _currentMappings.Select(m => $"{m.Source}>{m.Target}"));
        var handlerString = $"{_builderInput}->{_builderOutput} [{mapString}]";
        await OnApply.InvokeAsync(handlerString);
    }
}