@using System.Text.Json
@using DeviceSpace.Common.Contracts 
@using DeviceSpace.Common 
@using DeviceSpace.Common.Configurations

<div class="d-flex flex-row flex-grow-1 w-100" style="overflow: hidden;">
    
    <ToolkitSidebar OnItemDragStart="OnDragStart" />

    <div class="col-7 p-4 bg-light h-100 d-flex flex-column">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="text-dark fw-bold m-0"><i class="bi bi-layers-half"></i> Designer Canvas</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" @onclick="CollapseAll">Collapse All</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => { _deviceSpace.DeviceList.Clear(); _deviceSpace.WorkflowList.Clear(); }">Clear Canvas</button>
            </div>
        </div>

        <div class="canvas-container rounded p-4 flex-grow-1 overflow-auto" @ondragover:preventDefault @ondrop="OnDrop">
            @foreach (var device in _deviceSpace.DeviceList)
            {
                <div class="card mb-3 border-0 border-start border-4 border-danger shadow-sm">
                    <div class="card-header bg-white pt-2 pb-2 d-flex justify-content-between align-items-center collapse-header" @onclick="() => ToggleCollapse(device)">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi @(IsCollapsed(device) ? "bi-chevron-right" : "bi-chevron-down") text-secondary"></i>
                            <h6 class="m-0 text-danger fw-bold small">
                                <i class="bi @GetIconForManager(device.Manager) me-1"></i>
                                @device.Name 
                                <span class="text-muted fw-normal small ms-2" style="font-size: 0.7rem;">(@device.Manager)</span>
                            </h6>
                        </div>
                        <button class="btn btn-sm text-secondary p-0" @onclick:stopPropagation @onclick="() => RemoveDevice(device)"><i class="bi bi-x-lg"></i></button>
                    </div>
                    @if (!IsCollapsed(device))
                    {
                        <div class="card-body pt-2 pb-2 border-top bg-white">
                            <div class="row g-2 mb-2">
                                <div class="col-12"><input class="form-control form-control-sm border-danger-subtle" @bind="device.Name" placeholder="Device Name" /></div>
                            </div>
                            @if(device.Properties != null)
                            {
                                <div class="bg-light p-2 rounded border">
                                    @foreach(var key in device.Properties.Keys.ToList())
                                    {
                                        <div class="d-flex justify-content-between align-items-center prop-row">
                                            <span class="prop-label">@key</span>
                                            <input class="prop-input text-end" value="@device.Properties[key]" @onchange="@((ChangeEventArgs e) => UpdateProperty(device, key, e.Value))" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @foreach (var wf in _deviceSpace.WorkflowList)
            {
                <div class="card mb-3 border-0 border-start border-4 border-warning shadow-sm">
                    <div class="card-header bg-white pt-2 pb-2 d-flex justify-content-between align-items-center collapse-header" @onclick="() => ToggleCollapse(wf)">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi @(IsCollapsed(wf) ? "bi-chevron-right" : "bi-chevron-down") text-secondary"></i>
                            <h6 class="m-0 text-warning fw-bold small">
                                <i class="bi bi-diagram-3-fill me-1"></i> @wf.Name
                            </h6>
                        </div>
                        <button class="btn btn-sm text-secondary p-0" @onclick:stopPropagation @onclick="() => RemoveWorkflow(wf)"><i class="bi bi-x-lg"></i></button>
                    </div>
                    @if (!IsCollapsed(wf))
                    {
                        <div class="card-body pt-2 pb-2 border-top bg-white">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="fw-bold text-muted">Routes</small>
                                <button class="btn btn-xs btn-outline-warning text-dark py-0" style="font-size: 0.6rem;" @onclick="() => AddAdapter(wf)">+ Add Route</button>
                            </div>
                            @foreach(var route in wf.Routes)
                            {
                                <div class="p-2 bg-light border rounded mb-2 shadow-sm">
                                    <div class="input-group input-group-sm mb-1">
                                        <span class="input-group-text bg-light text-muted" style="width: 45px;">In</span>
                                        <input type="text" class="form-control" @bind="route.Source">
                                        <button class="btn btn-outline-secondary" @onclick="() => OpenTopicBuilder(route, true)"><i class="bi bi-tools"></i></button>
                                    </div>
                                    <div class="input-group input-group-sm mb-1">
                                        <span class="input-group-text bg-light text-muted" style="width: 45px;">Out</span>
                                        <input type="text" class="form-control" @bind="route.Destination">
                                        <button class="btn btn-outline-secondary" @onclick="() => OpenTopicBuilder(route, false)"><i class="bi bi-tools"></i></button>
                                    </div>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text"><i class="bi bi-shuffle"></i></span>
                                        <input type="text" class="form-control" @bind="route.Handler">
                                        <button class="btn btn-warning" @onclick="() => OpenHandlerBuilder(route)"><i class="bi bi-magic"></i></button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-3 bg-dark text-white p-0 d-flex flex-column border-start border-secondary h-100">
        <div class="p-3 bg-dark border-bottom border-secondary">
            <h6 class="m-0 text-warning small">Live JSON Output</h6>
        </div>
        <textarea readonly class="form-control bg-dark text-info border-0 w-100 h-100 p-3" style="font-family: monospace; font-size: 0.75rem;">@GetJson()</textarea>
    </div>

</div>

@if (_showTopicModal)
{
    <TopicBuilderModal 
        Devices="@_deviceSpace.DeviceList.Select(d => d.Name)"
        InitialDevice="@_deviceSpace.DeviceList.FirstOrDefault()?.Name"
        OnApply="ApplyTopic"
        OnClose="() => _showTopicModal = false" />
}

@if (_showHandlerModal)
{
    <HandlerBuilderModal 
        MessageSchemas="_messageSchemas"
        OnApply="ApplyHandler"
        OnClose="() => _showHandlerModal = false" />
}

@code {
    private DeviceSpace _deviceSpace = new DeviceSpace();
    private string _draggedType;
    private HashSet<object> _collapsedItems = new HashSet<object>();

    private Dictionary<string, List<string>> _messageSchemas = new() {
        { "DReqM", new() { "Gin", "Sku", "Qty", "StationId" } },
        { "LabelToPrint", new() { "PrinterName", "RawData", "JobId" } },
        { "StatusUpdate", new() { "DeviceId", "Code", "Message" } }
    };

    private bool _showTopicModal, _showHandlerModal, _isEditingSource;
    private WorkflowRoute _editingRoute;

    public string GetJson() => JsonSerializer.Serialize(new { 
        AppSettings = new { 
            Devices = _deviceSpace.DeviceList.ToDictionary(d => d.Name, d => d), 
            Workflows = _deviceSpace.WorkflowList.ToDictionary(w => w.Name, w => w) 
        } 
    }, new JsonSerializerOptions { WriteIndented = true });

    private void OnDragStart(string type) => _draggedType = type;

    private void OnDrop()
    {
        if (string.IsNullOrEmpty(_draggedType)) return;

        if (_draggedType == "Workflow") {
            _deviceSpace.WorkflowList.Add(new WorkflowConfig { Name = $"Workflow_{_deviceSpace.WorkflowList.Count + 1}", Enable = true });
        } else {
            var newDev = new DeviceConfig { Name = "New_Device", Manager = _draggedType, Enable = true, Properties = new() };
            switch (_draggedType) {
                case "PlcDevice":
                    newDev.Name = $"PLC_{_deviceSpace.DeviceList.Count + 1}";
                    newDev.Manager = "PlcDeviceManager";
                    newDev.Properties = new() { { "DevicePort", "6999" }, { "DeviceTimeout", "10000" } };
                    break;
                case "ActiveMqDevice":
                    newDev.Name = $"Broker_{_deviceSpace.DeviceList.Count + 1}";
                    newDev.Manager = "ActiveMQManager";
                    newDev.Properties = new() { { "ConnectionString", "tcp://localhost:61616" }, { "DoubleQueue", true } };
                    break;
                case "PrinterDevice":
                    newDev.Name = $"P{(_deviceSpace.DeviceList.Count + 1).ToString("D3")}";
                    newDev.Manager = "PrinterManager";
                    newDev.Properties = new() { { "IPAddress", "127.0.0.1" }, { "PrintPort", 9100 }, { "Brand", "Zebra" } };
                    break;
                case "VirtualPlcDevice":
                    newDev.Name = $"VirtPLC_{_deviceSpace.DeviceList.Count + 1}";
                    newDev.Manager = "VirtualPlcManager";
                    newDev.Properties = new() { { "IPAddress", "127.0.0.1" }, { "Port", 5000 } };
                    break;
                case "VirtualPrinterDevice":
                    newDev.Name = $"VirtP{(_deviceSpace.DeviceList.Count + 1).ToString("D3")}";
                    newDev.Manager = "VirtualPrinterManager";
                    newDev.Properties = new() { { "Port", 9100 } };
                    break;
            }
            _deviceSpace.DeviceList.Add(newDev);
        }
        StateHasChanged();
    }

    private string GetIconForManager(string m) => m switch {
        string s when s.Contains("Plc") => "bi-hdd-rack-fill text-danger",
        string s when s.Contains("ActiveMq") => "bi-envelope-paper-fill text-info",
        string s when s.Contains("Printer") => "bi-printer-fill text-warning",
        _ => "bi-cpu-fill text-white-50"
    };

    private void ToggleCollapse(object i) { if(_collapsedItems.Contains(i)) _collapsedItems.Remove(i); else _collapsedItems.Add(i); }
    private bool IsCollapsed(object i) => _collapsedItems.Contains(i);
    
    private void CollapseAll()
    {
        foreach(var d in _deviceSpace.DeviceList) _collapsedItems.Add(d);
        foreach(var w in _deviceSpace.WorkflowList) _collapsedItems.Add(w);
    }

    private void UpdateProperty(DeviceConfig d, string k, object v) { if(d.Properties.ContainsKey(k)) d.Properties[k] = v; }
    private void RemoveDevice(DeviceConfig d) => _deviceSpace.DeviceList.Remove(d);
    
    private void AddAdapter(WorkflowConfig wf) => wf.Routes.Add(new WorkflowRoute { Source = "In", Destination = "Out", Handler = "DefaultHandler" });
    private void RemoveWorkflow(WorkflowConfig w) => _deviceSpace.WorkflowList.Remove(w);

    private void OpenTopicBuilder(WorkflowRoute r, bool isSrc) 
    { 
        _editingRoute = r; 
        _isEditingSource = isSrc; 
        _showTopicModal = true; 
    }

    private void ApplyTopic(string topicString) 
    { 
        if (_isEditingSource) _editingRoute.Source = topicString; 
        else _editingRoute.Destination = topicString; 
        _showTopicModal = false; 
    }

    private void OpenHandlerBuilder(WorkflowRoute r) 
    { 
        _editingRoute = r; 
        _showHandlerModal = true; 
    }

    private void ApplyHandler(string handlerString) 
    { 
        _editingRoute.Handler = handlerString; 
        _showHandlerModal = false; 
    }
}