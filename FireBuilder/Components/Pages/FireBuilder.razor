@page "/configurator"
@using System.Text.Json
@using DeviceSpace.Common.Contracts 
@using DeviceSpace.Common 
@using DeviceSpace.Common.Configurations

<style>
    .toolbox-item {
        cursor: grab;
        transition: all 0.2s;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .toolbox-item:active {
        cursor: grabbing;
    }
    .toolbox-item:hover {
        background-color: rgba(255,255,255,0.1) !important;
        transform: translateX(5px);
    }
    /* Make the entire page full height */
    .viewport-container {
        min-height: 100vh;
    }
</style>

<div class="container-fluid viewport-container d-flex flex-column p-0">
    <nav class="navbar navbar-dark bg-dark border-bottom border-secondary px-3">
        <a class="navbar-brand" href="#">
            <i class="bi bi-boxes"></i> DeviceSpace Configurator
        </a>
        <button class="btn btn-sm btn-outline-light" @onclick="DownloadJson">
            <i class="bi bi-download"></i> Export JSON
        </button>
    </nav>

    <div class="row g-0 flex-grow-1">
        <div class="col-md-2 bg-dark text-white p-3 d-flex flex-column">
            
            <h6 class="text-uppercase text-muted mb-3" style="font-size: 0.8rem; font-weight: bold;">
                Component Library
            </h6>

            <div class="nav flex-column nav-pills gap-2">
                <div class="nav-link text-white bg-transparent toolbox-item d-flex align-items-center gap-2" 
                     draggable="true" 
                     @ondragstart="@(() => OnDragStart("Device"))">
                    <i class="bi bi-hdd-rack fs-5 text-primary"></i> 
                    <div>
                        <div class="fw-bold">Standard Device</div>
                        <small class="text-muted" style="font-size:0.7em">Gen purpose PLC</small>
                    </div>
                </div>

                <div class="nav-link text-white bg-transparent toolbox-item d-flex align-items-center gap-2" 
                     draggable="true" 
                     @ondragstart="@(() => OnDragStart("Scanner"))">
                    <i class="bi bi-upc-scan fs-5 text-warning"></i>
                    <div>
                        <div class="fw-bold">Scanner</div>
                        <small class="text-muted" style="font-size:0.7em">Barcode reader</small>
                    </div>
                </div>

                <div class="nav-link text-white bg-transparent toolbox-item d-flex align-items-center gap-2" 
                     draggable="true" 
                     @ondragstart="@(() => OnDragStart("Workflow"))">
                    <i class="bi bi-diagram-3 fs-5 text-success"></i>
                    <div>
                        <div class="fw-bold">Workflow</div>
                        <small class="text-muted" style="font-size:0.7em">Logic & Routes</small>
                    </div>
                </div>
            </div>

            <hr class="text-secondary mt-auto" />
            
            <div class="alert alert-info py-2" style="font-size: 0.8rem">
                <i class="bi bi-info-circle"></i> Drag items from this menu to the canvas on the right.
            </div>
        </div>

        <div class="col-md-10 d-flex flex-column bg-light">
            
            <div class="row h-100 g-0">
                <div class="col-md-8 p-4" style="overflow-y: auto;">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="text-dark">Layout Canvas</h4>
                        <span class="badge bg-secondary">@(_deviceSpace.DeviceList.Count + _deviceSpace.WorkflowList.Count) Objects</span>
                    </div>

                    <div class="border rounded shadow-sm p-4 bg-white" 
                         style="min-height: 600px; border-style: dashed !important; border-width: 2px;" 
                         @ondragover:preventDefault @ondrop="OnDrop">
                        
                        @if (_deviceSpace.DeviceList.Count == 0 && _deviceSpace.WorkflowList.Count == 0)
                        {
                            <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-50">
                                <i class="bi bi-box-arrow-in-down fs-1"></i>
                                <p class="mt-2">Canvas Empty</p>
                            </div>
                        }

                        @foreach (var device in _deviceSpace.DeviceList)
                        {
                            <div class="card mb-3 border-start border-4 border-primary shadow-sm">
                                <div class="card-body py-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="card-title m-0 text-primary">
                                            <i class="bi bi-hdd-rack"></i> @device.Name
                                        </h6>
                                        <button class="btn btn-link text-danger p-0" @onclick="() => RemoveDevice(device)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <input class="form-control form-control-sm" @bind="device.Name" @bind:event="oninput" placeholder="Device Name" />
                                        </div>
                                        <div class="col-6">
                                            <select class="form-select form-select-sm" @bind="device.Manager">
                                                <option value="PlcManager">PLC</option>
                                                <option value="ScannerManager">Scanner</option>
                                                <option value="PrinterManager">Printer</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        @foreach (var wf in _deviceSpace.WorkflowList)
                        {
                            <div class="card mb-3 border-start border-4 border-success shadow-sm">
                                <div class="card-body py-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="card-title m-0 text-success">
                                            <i class="bi bi-diagram-3"></i> @wf.Name
                                        </h6>
                                        <button class="btn btn-link text-danger p-0" @onclick="() => RemoveWorkflow(wf)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    
                                    <div class="row g-2 mb-2">
                                        <div class="col-12">
                                            <input class="form-control form-control-sm" @bind="wf.Name" @bind:event="oninput" placeholder="Workflow Name" />
                                        </div>
                                    </div>

                                    <div class="bg-light p-2 rounded border">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="fw-bold text-muted">Adapters</small>
                                            <button class="btn btn-xs btn-outline-success py-0" style="font-size: 0.7rem" @onclick="() => AddAdapter(wf)">+ Add</button>
                                        </div>
                                        @if(wf.Routes.Any())
                                        {
                                            <ul class="list-group mt-1">
                                                @foreach(var route in wf.Routes)
                                                {
                                                    <li class="list-group-item py-1 px-2 d-flex justify-content-between align-items-center" style="font-size: 0.8rem">
                                                        <span>@route.Source &rarr; @route.Destination</span>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-md-4 border-start bg-white p-0 d-flex flex-column h-100">
                    <div class="p-3 bg-light border-bottom">
                        <h6 class="m-0"><i class="bi bi-code-slash"></i> Live Configuration</h6>
                    </div>
                    <div class="flex-grow-1 bg-dark">
                        <pre class="text-light p-3 m-0 border-0" style="font-size: 0.75rem; overflow: auto; height: 100%;">@GetJson()</pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private DeviceSpace _deviceSpace = new DeviceSpace();
    private string _draggedType;

    private void OnDragStart(string type)
    {
        _draggedType = type;
    }

    private void OnDrop()
    {
        if (_draggedType == "Device" || _draggedType == "Scanner")
        {
            _deviceSpace.DeviceList.Add(new DeviceConfig 
            { 
                Name = $"New{_draggedType}_{_deviceSpace.DeviceList.Count + 1}",
                Manager = _draggedType == "Scanner" ? "ScannerManager" : "PlcManager",
                Enable = true
            });
        }
        else if (_draggedType == "Workflow")
        {
            _deviceSpace.WorkflowList.Add(new WorkflowConfig 
            { 
                Name = $"NewWorkflow_{_deviceSpace.WorkflowList.Count + 1}",
                Type = "DefaultWorkflow",
                Enable = true
            });
        }
    }

    private void RemoveDevice(IDeviceConfig dev) => _deviceSpace.DeviceList.Remove((DeviceConfig)dev);
    private void RemoveWorkflow(WorkflowConfig wf) => _deviceSpace.WorkflowList.Remove(wf);

    private void AddAdapter(WorkflowConfig wf)
    {
        wf.Routes.Add(new WorkflowRoute() 
        { 
            Mode = 0,
            Source = "Topic.In", 
            Destination = "Topic.Out",
            Handler = "DefaultHandler"
        });
    }

    private string GetJson()
    {
        var options = new JsonSerializerOptions { WriteIndented = true };
        var root = new { AppSettings = new { DeviceSpace = _deviceSpace } };
        return JsonSerializer.Serialize(root, options);
    }

    private async Task DownloadJson()
    {
        Console.WriteLine("JSON Generated for Download");
        // Implementation for download would go here
    }
}