# ==============================================
# --- WCS Specific: Logging & Config ---
# ==============================================
# Keep the folder, ignore the actual log files from your WCS
logs/
*.log
# Specifically ignore the audit and GIN logs generated by your Serilog config
logs/audit/
logs/gin/
logs/app/

# ==============================================
# --- Security: Don't leak PLC/Broker Credentials ---
# ==============================================
appsettings.Development.json
appsettings.Local.json
*.usersecrets
UserSecrets/
# Ignore any temp device space JSONs generated by FireBuilder
DeviceSpace.json

# ==============================================
# --- Database & SQL (Since you're migrating from SQL 2000) ---
# ==============================================
*.mdf
*.ldf
*.bak
# Ignore local SQLite DBs if used for testing
*.db
*.sqlite

# ==============================================
# --- Test Results ---
# ==============================================
TestResults/
*.trx
*.vstest
*.coveragestack
*.coverage

# ==============================================
# --- OS & Environment ---
# ==============================================
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

