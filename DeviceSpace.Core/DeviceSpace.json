            {
              "Mode": 0,
              "Name": "Route3-VerifyRequestToQueue",
              "Source": "TPNA2.DReqM.Verification",
              "Handler": "HandleLabelVerificationToMqAsync",
              "Destination": "TBROKER.LabelVerifyFrcMessage.AC.PNA.LABELVERIFY"
            },{
              "Mode": 0,
              "Name": "Route4-QueueToMemory",
              "Source": "TBROKER.LabelDataFrcMessage.AC.PNA.LABELDATA",
              "Handler": "HandleLabelToStorageAsync",
              "Destination": "PrintAndApplyFrc.LabelToPrint.Storage"
              
            },{
              "Mode": 0,
              "Name": "Route5-PrintRequestToPrinter1",
              "Source": "TPNA2.DReqM.PNA2 152",
              "Destination": "P001.LabelToPrint.None",
              "Handler": "HandleBarcodeToPrinterAsync"
            },{
              "Mode": 0,
              "Name": "Route6-PrintRequestToPrinter2",
              "Source": "TPNA2.DReqM.PNA2 153",
              "Destination": "P002.LabelToPrint.None",
              "Handler": "HandleBarcodeToPrinterAsync"
            },{
              "Mode": 0,
              "Name": "Route7-PrintRequestToPrinter3",
              "Source": "TPNA2.DReqM.I001",
              "Handler": "HandleContentToPrinterAsync",
              "Destination": "I001.LabelToPrint.None"
            },{
              "Mode": 1,
              "Name": "Route8-PrintRequestToPrinter4",
              "Source": "TPNA2.DReqM.I002",
              "Handler": "HandleContentToPrinterAsync",
              "Destination": "I002.LabelToPrint.None"
            }
          ]
        }
      ],
