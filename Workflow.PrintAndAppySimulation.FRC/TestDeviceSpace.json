{
  "AppSettings": {
    "DeviceSpace": {
      "Name": "Fire-PnA-Simulation",
      "DeviceList": [
        {
          "Name": "TBROKER",
          "Manager": "ActiveMQManager",
          "Enable": true,
          "Properties": {
            "ConnectionString": "tcp://127.0.0.1:61616?useKeepAlive=true",
            "DoubleQueue": true
          }
        },
        {
          "Name": "TPNA2",
          "Manager": "VirtualPlcManager",
          "Enable": true,
          "Properties": {
            "IPAddress": "127.0.0.1",
            "Port": 6999,
            "DecisionPoints":  "PNALINE-2:0",
            "TotalTotes": 10,
            "InductionFreq": 10000
          }
        },
        {
          "Name": "PNA2 151",
          "Manager": "VirtualPrinterManager",
          "Enable": true,
          "Properties": {
            "Port": 9100
          }
        },
        {
          "Name": "PNA2 152",
          "Manager": "VirtualPrinterManager",
          "Enable": true,
          "Properties": {
            "Port": "9101"
          }
        },
        {
          "Name": "vI001",
          "Manager": "VirtualPrinterManager",
          "Enable": false,
          "Properties": {
            "Port": 9102
          }
        },
        {
          "Name": "vI002",
          "Manager": "VirtualPrinterManager",
          "Enable": false,
          "Properties": {
            "Port": 9103
          }
        }
      ],
      "WorkflowList": [
        {
          "Name": "Wf.TestPAndA.FRC",
          "Type": "PrintAndApplyFrcSimulation",
          "Enable": true,
          "IsSimulation": true,
          "TotalTotes": 100,
          "InductionIntervalMs": 1000,
          "Routes": [
            {
              "Mode": 1,
              "Name": "Route1-LabelRequest",
              "Source": "TBROKER.LabelRequestFrcMessage.AC.PNA.LABELREQUEST",
              "Destination": "TBROKER.LabelDataFrcMessage.AC.PNA.LABELDATA",
              "Handler": "HandleLabelRequest"
            }
          ]
        }
      ]
    }
  }
}
      
